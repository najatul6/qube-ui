{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",

    "moduleResolution": "Bundler",

    "strict": true,

    "declaration": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "allowSyntheticDefaultImports": true,

    "forceConsistentCasingInFileNames": true
  }
}